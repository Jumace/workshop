{
  "name": "julian-cebulla",
  "private": true,
  "scripts": {
    "build": "opennextjs-cloudflare build",
    "build:next": "node scripts/generate-content-registry.mjs && next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy": "pnpm build && opennextjs-cloudflare deploy",
    "dev": "next dev --turbopack",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "typecheck": "node scripts/generate-content-registry.mjs && tsc --noEmit -p tsconfig.typecheck.json",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "validate:content": "node scripts/validate-content.mjs",
    "check:spelling": "cspell --no-progress"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@types/mdx": "^2.0.14",
    "clsx": "^2.1.1",
    "flags": "^4.2.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "rehype-pretty-code": "^0.14.4",
    "typescript": "5.7.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "cspell": "^10.0.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "wrangler": "^4.112.0"
  },
  "packageManager": "pnpm@11.3.0"
}
